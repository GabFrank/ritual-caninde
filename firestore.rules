rules_version = '2';

// ⚠️ DIAGNÓSTICO TEMPORAL — exige únicamente estar autenticado (no chequea dueño).
// Sirve para aislar si `request.auth` llega a Firestore. Se restaura a las reglas por
// dueño en cuanto se confirme la causa. Aplica sólo a la base de Ritual (ai-studio-44008411).
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
